# Copy to .env.local and fill in values. Never commit .env.local.

# --- Supabase (required for app) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Postgres migrations (`npm run db:apply`) ---
# Option A: full URI from Dashboard → Settings → Database (use direct or pooler + ?sslmode=require)
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Option B: database user password only (script builds URI from NEXT_PUBLIC_SUPABASE_URL above)
# SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# --- AI (optional, feature-dependent) ---
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_TEXT_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.0-flash

# --- AWS Polly TTS (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
AWS_POLLY_VOICE_ID=Takumi

NEXT_PUBLIC_APP_URL=http://localhost:3001

# Google sign-in (Supabase): Google Cloud OAuth "Web application"
# - Authorized redirect URIs: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# - Authorized JavaScript origins: your app origin (e.g. http://localhost:3001)
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3001/auth/callback
#   https://your-production-domain/auth/callback
